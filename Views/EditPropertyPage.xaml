<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PropertyManagerApp.Views.EditPropertyPage"
             Title="Edit Property">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Label Text="Property Name *" FontAttributes="Bold" />
            <Entry x:Name="NameEntry" />

            <Label Text="Address" FontAttributes="Bold" />
            <Entry x:Name="AddressEntry" />

            <Label Text="Unit Number" FontAttributes="Bold" />
            <Entry x:Name="UnitEntry" />

            <Label Text="Monthly Rent ($)" FontAttributes="Bold" />
            <Entry x:Name="RentEntry" Keyboard="Numeric" />

            <Button Text="Save Changes"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#639922"
                    TextColor="White"
                    Margin="0,10,0,0" />

            <Button Text="Cancel"
                    Clicked="OnCancelClicked"
                    BackgroundColor="#888780"
                    TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>